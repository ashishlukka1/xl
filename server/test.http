### Step 1: login as the existing CSM user
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}
# Copy the "token" value from this response and paste it into:
# @token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiI2YTQxNzZjN2I1Y2Y1ZTJkZjRjMTA3YWQiLCJpYXQiOjE3ODI3MTc1NDAsImV4cCI6MTc4MzMyMjM0MH0.FF4G0utAHS_xTAdJ12Z93DR_HJsx0Ood59ekryjNnDs

### Step 2: confirm the user session
GET {{baseUrl}}/api/auth/me
Authorization: Bearer {{token}}

### Step 3: confirm playbooks were injected
GET {{baseUrl}}/api/playbooks
Authorization: Bearer {{token}}

### Step 4: confirm the injected client is visible to the CSM
GET {{baseUrl}}/api/clients
Authorization: Bearer {{token}}

### Step 5: confirm raw events were injected for the demo client
GET {{baseUrl}}/api/clients/{{clientRouteId}}/events
Authorization: Bearer {{token}}

### Step 6: perform the actual planner run
POST {{baseUrl}}/api/clients/{{clientRouteId}}/runs
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "triggered_by": "manual"
}

### Step 7: inspect the generated client detail payload
GET {{baseUrl}}/api/clients/{{clientRouteId}}
Authorization: Bearer {{token}}

### Step 8: inspect generated recommendations only
GET {{baseUrl}}/api/clients/{{clientRouteId}}/recommendations
Authorization: Bearer {{token}}

### Step 9: inspect dashboard aggregation
GET {{baseUrl}}/api/dashboard
Authorization: Bearer {{token}}

### Step 10: approve one generated recommendation
# Replace @recommendationId with a real recommendation _id from Step 7 or Step 8.
PATCH {{baseUrl}}/api/recommendations/{{recommendationId}}/decision
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "decision": "approved"
}

### Step 11: inspect memory outcomes created by the approval
GET {{baseUrl}}/api/clients/{{clientRouteId}}
Authorization: Bearer {{token}}
